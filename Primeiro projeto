<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <title>Médicos e Exames</title>
    <style>
/* Reset básico */
* {
  box-sizing: border-box;
  font-family: Arial, Helvetica, sans-serif;
}

body {
 
  background-color: rgb(118, 128, 118);
  background-position: center center; /* centraliza horizontal e vertical */
  background-size: cover;             /* preenche a tela sem distorcer */
  background-repeat: no-repeat;       /* não repete */
  min-height: 100vh;
  margin: 0;

  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* Título */
h2 {
  background-color: rgb(38, 196, 38);
  color: #fff;
  border-radius: 8px;
  padding: 10px 16px;
  margin-bottom: 20px;
}

/* Select */
select {
  margin-bottom: 15px;
  padding: 8px 12px;
  border-radius: 6px;
  border: 1px solid #999;
  font-size: 15px;
  cursor: pointer;
}

select:focus {
  outline: none;
  border-color: green;
}

/* Tabela */
table {
  border-collapse: collapse;
  margin-top: 15px;
  width: 100%;
  max-width: 600px;
  background-color: #fff;
  box-shadow: 0 6px 15px rgba(0,0,0,0.1);
  border-radius: 6px;
  overflow: hidden;
}

th, td {
  padding: 10px;
  text-align: left;
}

th {
  background-color: green;
  color: white;
}

/* Linhas alternadas */
tr:nth-child(even) td {
  background-color: #f2f2f2;
}

/* Infos */
#informacoes,
#medico,#Preparos {
  color: rgb(35, 160, 44);
  font-weight: bold;
  margin-top: 10px;
 
  
}

    </style>
</head>
<body>

