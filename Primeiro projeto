    <style>
/* Reset básico */
* {
  box-sizing: border-box;
  font-family: "Segoe UI", Arial, Helvetica, sans-serif;
}

/* BODY */
body {
 background: linear-gradient(135deg, #f4f6f8, #e6eaee);
  min-height: 100vh;
  margin: 0;

  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* TÍTULO */
h2 {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
  border-radius: 10px;
  padding: 12px 20px;
  margin-bottom: 25px;
  font-weight: 600;
  letter-spacing: 0.5px;
  box-shadow: 0 6px 12px rgba(0,0,0,0.15);
}

/* SELECT */
select {
  margin-bottom: 12px;
  padding: 10px 14px;
  border-radius: 8px;
  border: 1px solid #4caf50;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  background-color: #f4fff8;
  transition: all 0.25s ease;
}

select:hover {
  background-color: #e8fff1;
}

select:focus {
  outline: none;
  border-color: #2ecc71;
  box-shadow: 0 0 0 2px rgba(46, 204, 113, 0.35);
}

/* TABELA */
table {
  border-collapse: collapse;
  margin-top: 20px;
  width: 100%;
  max-width: 650px;
  background-color: #fff;
  box-shadow: 0 8px 18px rgba(0,0,0,0.12);
  border-radius: 10px;
  overflow: hidden;
  animation: fadeIn 0.4s ease;
}

th, td {
  padding: 12px;
  text-align: left;
}

th {
  background-color: #2ecc71;
  color: #fff;
  font-weight: 600;
}

/* LINHAS */
tr:nth-child(even) td {
  background-color: #f6fdf9;
}

tr:hover td {
  background-color: #e9f8ef;
}

/* SELECTS (IDS) */
#informacoes,
#medico,
#Preparos,
#Autorizacao,
#Valores {
  color: #0f8adb;
  font-weight: 600;
  margin-top: 10px;
}

/* CONTEINER (mantendo sua estrutura) */
conteiner {
  border: 2px solid #2ecc71;
  border-radius: 12px;
  background-color: #44b635;
  padding: 12px;
  background: linear-gradient(135deg, #2ecc71, #27ae60);
}



    </style>
